      "id": "055c3a2b-6e32-4f0d-9d60-e4f5d54d5511",
      "name": "Alert Status"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://opensearch-hot:9200/crowdsec-events-*/_search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"size\": 0,\n  \"query\": {\n    \"bool\": {\n      \"must\": [\n        { \"range\": { \"@timestamp\": { \"gte\": \"now-1h\" } } },\n        { \"query_string\": { \"query\": \"message:\\\"ban on Ip\\\"\" } }\n      ]\n    }\n  },\n  \"aggs\": {\n    \"banned_ips\": {\n      \"terms\": { \"field\": \"message.keyword\", \"size\": 10 }\n    },\n    \"by_program\": {\n      \"terms\": { \"field\": \"program.keyword\", \"size\": 5 }\n    },\n    \"by_source\": {\n      \"terms\": { \"field\": \"source_host.keyword\", \"size\": 5 }\n    }\n  }\n}",
        "options": {
          "timeout": 10000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        608,
        208
      ],
      "id": "88986fe0-2b14-4d73-ab44-e124a7415f57",
      "name": "Query OpenSearch Bans"
    },
    {
      "parameters": {
        "jsCode": "// Extract enrichment data from OpenSearch response\nconst osData = $input.first().json;\nconst grafanaAlert = $('CrowdSec Webhook').first().json.body;\nconst alert = (grafanaAlert.alerts || [{}])[0];\n\n// Parse aggregation results\nconst totalBans = osData.hits?.total?.value || 0;\nconst bannedIps = (osData.aggregations?.banned_ips?.buckets || [])\n  .map(b => {\n    // Extract IP from ban message like \"ban on Ip 1.2.3.4\"\n    const match = b.key.match(/ban on Ip\\s+([\\d.]+)/);\n    return match ? `\\`${match[1]}\\` (${b.doc_count}x)` : `${b.key.slice(0, 40)} (${b.doc_count}x)`;\n  })\n  .slice(0, 8)\n  .join('\\n') || 'None in last hour';\n\nconst programs = (osData.aggregations?.by_program?.buckets || [])\n  .map(b => `${b.key}: ${b.doc_count}`)\n  .join(', ') || 'N/A';\n\nconst sources = (osData.aggregations?.by_source?.buckets || [])\n  .map(b => `${b.key}: ${b.doc_count}`)\n  .join(', ') || 'N/A';\n\nreturn [{\n  json: {\n    alertName: alert.labels?.alertname || 'CrowdSec Alert',\n    severity: alert.labels?.severity || 'warning',\n    summary: alert.annotations?.summary || 'CrowdSec ban decision surge detected',\n    description: alert.annotations?.description || '',\n    startsAt: alert.startsAt || new Date().toISOString(),\n    dashboardURL: alert.dashboardURL || '',\n    panelURL: alert.panelURL || '',\n    totalBans,\n    bannedIps,\n    programs,\n    sources,\n    labels: alert.labels || {}\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        208
      ],
      "id": "dbda92f8-b453-4ae6-8cca-caf1d87b892f",
      "name": "Enrich Alert Data"
    },
    {
      "parameters": {
        "authentication": "webhook",
        "operation": "sendLegacy",
        "content": "",
        "embeds": {
          "values": [
            {
              "title": "=🛡️ CrowdSec — {{ $json.alertName }}",
              "description": "={{ $json.summary }}",
              "color": 15105570,
              "timestamp": "={{ $json.startsAt }}",
              "fields": [
                {
                  "name": "⚠️ Severity",
                  "value": "={{ $json.severity }}",
                  "inline": true
                },
                {
                  "name": "📊 Total Bans (1h)",
                  "value": "=**{{ $json.totalBans }}** bans detected",
                  "inline": true
                },
                {
                  "name": "🤖 Programs Active",
                  "value": "={{ $json.programs }}",
                  "inline": true
                },
                {
                  "name": "🌐 Recently Banned IPs",
                  "value": "={{ $json.bannedIps }}",
                  "inline": false
                },
                {
                  "name": "🏠 Source Hosts",
                  "value": "={{ $json.sources }}",
                  "inline": false
                },
                {
                  "name": "🕐 Started At",
                  "value": "={{ $json.startsAt }}",
                  "inline": true
                },
                {
                  "name": "📋 Description",
                  "value": "={{ ($json.description || 'N/A').slice(0, 900) }}",
                  "inline": false
                },
                {
                  "name": "🔗 Dashboard",
                  "value": "={{ $json.dashboardURL || 'N/A' }}",
                  "inline": false
                },
                {
                  "name": "📎 Labels",
                  "value": "={{ Object.entries($json.labels || {}).map(([k,v]) => k + '=' + v).join(', ').slice(0, 400) || 'N/A' }}",
                  "inline": false
                }
              ]
            }
          ]
        }
      },
