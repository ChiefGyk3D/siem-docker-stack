  "id": null,
  "uid": "nvidia-gpu-monitoring",
  "title": "NVIDIA GPU Monitoring",
  "description": "GPU utilization, temperature, VRAM, power, encoder/decoder, and fan metrics for NVIDIA GPUs across Linux (dcgm-exporter) and Windows (nvidia_gpu_exporter).",
  "tags": ["nvidia", "gpu", "prometheus", "dcgm"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "id": 1,
      "title": "GPU Utilization — All Machines",
      "description": "Current GPU utilization percentage for all monitored GPUs",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL{job=\"nvidia-dcgm\"}",
          "legendFormat": "{{instance_name}} GPU{{gpu}}",
          "refId": "A"
        },
        {
          "expr": "nvidia_smi_gpu_utilization_gpu{job=\"nvidia-gpu-windows\"}",
          "legendFormat": "{{instance_name}} GPU{{index}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "GPU Temperature — All Machines",
      "description": "Current GPU temperature for all monitored GPUs",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 30 },
              { "color": "yellow", "value": 65 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP{job=\"nvidia-dcgm\"}",
          "legendFormat": "{{instance_name}} GPU{{gpu}}",
          "refId": "A"
        },
        {
          "expr": "nvidia_smi_temperature_gpu{job=\"nvidia-gpu-windows\"}",
          "legendFormat": "{{instance_name}} GPU{{index}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "VRAM Used — All Machines",
      "description": "Framebuffer / VRAM usage across all GPUs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8000 },
              { "color": "red", "value": 14000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED{job=\"nvidia-dcgm\"}",
          "legendFormat": "{{instance_name}} GPU{{gpu}}",
          "refId": "A"
        },
        {
          "expr": "nvidia_smi_memory_used_bytes{job=\"nvidia-gpu-windows\"} / 1048576",
          "legendFormat": "{{instance_name}} GPU{{index}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Power Draw — All Machines",
      "description": "Current GPU power consumption in watts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 350 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE{job=\"nvidia-dcgm\"}",
          "legendFormat": "{{instance_name}} GPU{{gpu}}",
          "refId": "A"
        },
        {
          "expr": "nvidia_smi_power_draw_watts{job=\"nvidia-gpu-windows\"}",
          "legendFormat": "{{instance_name}} GPU{{index}}",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 101,
      "title": "GPU Utilization Over Time",
      "type": "row"
    },
    {
      "id": 10,
      "title": "GPU Utilization % — Time Series",
