        "title": "Recent JumpCloud Events",
        "type": "table",
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 36 },
        "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds}" },
        "targets": [
          {
            "query": "rule.groups:jumpcloud",
            "metrics": [
              {
                "type": "raw_data",
                "id": "1",
                "settings": { "size": "50" }
              }
            ],
            "bucketAggs": [],
            "timeField": "timestamp"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
