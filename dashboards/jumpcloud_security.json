{
  "dashboard": {
    "id": null,
    "uid": "jumpcloud-security",
    "title": "JumpCloud IdP Security",
    "description": "JumpCloud Directory Insights — auth events, user lifecycle, SSO, RADIUS, LDAP, policy changes",
    "tags": ["jumpcloud", "idp", "security", "wazuh"],
    "timezone": "browser",
    "editable": true,
    "graphTooltip": 1,
    "refresh": "5m",
    "time": { "from": "now-24h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "ds",
          "type": "datasource",
          "query": "opensearch",
          "current": { "text": "Wazuh", "value": "dff8stu43lr7kc" },
          "hide": 0,
          "label": "Datasource"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Auth Failures Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds}" },
        "targets": [
          {
            "query": "rule.groups:jumpcloud AND rule.groups:authentication_failed",
            "metrics": [{ "type": "count", "id": "1" }],
            "bucketAggs": [
              {
                "type": "date_histogram",
                "field": "timestamp",
                "id": "2",
                "settings": { "interval": "auto", "min_doc_count": "0" }
              }
            ],
            "timeField": "timestamp"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "red" },
            "custom": {
              "fillOpacity": 20,
              "lineWidth": 2,
              "drawStyle": "line",
              "pointSize": 5,
              "showPoints": "auto"
            }
          }
        },
        "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } }
      },
      {
        "id": 2,
        "title": "Auth Success Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds}" },
        "targets": [
          {
            "query": "rule.groups:jumpcloud AND rule.groups:authentication_success",
            "metrics": [{ "type": "count", "id": "1" }],
            "bucketAggs": [
              {
                "type": "date_histogram",
                "field": "timestamp",
                "id": "2",
                "settings": { "interval": "auto", "min_doc_count": "0" }
              }
            ],
            "timeField": "timestamp"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "green" },
            "custom": {
              "fillOpacity": 20,
              "lineWidth": 2,
              "drawStyle": "line",
              "pointSize": 5,
              "showPoints": "auto"
            }
          }
        },
        "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "single" } }
      },
      {
        "id": 3,
        "title": "Total Auth Failures",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
        "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds}" },
        "targets": [
          {
            "query": "rule.groups:jumpcloud AND rule.groups:authentication_failed",
            "metrics": [{ "type": "count", "id": "1" }],
            "bucketAggs": [],
            "timeField": "timestamp"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "red" },
            "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 10, "color": "yellow" }, { "value": 50, "color": "red" }] }
          }
        }
      },
      {
        "id": 4,
        "title": "Total Auth Success",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
