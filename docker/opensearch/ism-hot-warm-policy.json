{
  "policy": {
    "description": "Hot/Warm/Delete lifecycle for SIEM indices. Hot (NVMe, 0-30d) → Warm (SATA, 30d-1yr) → Delete (>1yr).",
    "default_state": "hot",
    "ism_template": [
      {
        "index_patterns": ["suricata-*"],
        "priority": 100
      },
      {
        "index_patterns": ["syslog-*"],
        "priority": 100
      },
      {
        "index_patterns": ["pfblockerng-*"],
        "priority": 100
      }
    ],
    "states": [
      {
        "name": "hot",
        "actions": [
          {
            "allocation": {
              "require": {
                "temp": "hot"
              }
            }
          },
          {
            "replica_count": {
              "number_of_replicas": 0
            }
          }
        ],
        "transitions": [
          {
            "state_name": "warm",
            "conditions": {
              "min_index_age": "30d"
            }
          }
        ]
      },
      {
        "name": "warm",
        "actions": [
          {
            "allocation": {
              "require": {
                "temp": "warm"
              }
            }
          },
          {
            "replica_count": {
              "number_of_replicas": 0
            }
          },
          {
            "force_merge": {
              "max_num_segments": 1
            }
          },
          {
            "index_priority": {
              "priority": 50
            }
          }
        ],
        "transitions": [
          {
            "state_name": "delete",
            "conditions": {
              "min_index_age": "365d"
            }
          }
        ]
      },
      {
        "name": "delete",
        "actions": [
          {
            "notification": {
              "destination": {
                "custom_webhook": {
                  "url": "http://localhost:9200/_plugins/_ism/explain"
                }
              },
              "message_template": {
                "source": "Index {{ctx.index}} is being deleted after 365 days (1 year)."
              }
            }
          },
          {
            "delete": {}
          }
        ],
        "transitions": []
      }
    ]
  }
}
