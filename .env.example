# =============================================================================
# SIEM Docker Stack — Environment Configuration
# =============================================================================
# Copy this file to .env in the docker/ directory (or repo root for
# 03-deploy.sh) and customize ALL values below.
#
#   cp .env.example .env
#   nano .env
#
# NEVER commit .env to version control — it contains credentials.
# =============================================================================

# ── Network ───────────────────────────────────────────────────────────────────
# IP address of your SIEM server (used for Grafana root URL, etc.)
SIEM_HOST=10.0.0.100

# Your username on the SIEM server (for SSH deployments)
SIEM_USER=siem

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_VERSION=2.19.0
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601

# JVM heap per node — should be ≤50% of available RAM, split across nodes.
# Example for 64GB total: hot=12g, warm=4g, wazuh-indexer=4g (20g JVM total)
OPENSEARCH_HOT_HEAP=12g
OPENSEARCH_WARM_HEAP=4g

# ── Logstash ──────────────────────────────────────────────────────────────────
LOGSTASH_HEAP=2g
LOGSTASH_UDP_PORT=5140
LOGSTASH_BEATS_PORT=5044

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASS=changeme

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUXDB_PORT=8086
INFLUXDB_DB=pfsense

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=365d

# ── Wazuh ─────────────────────────────────────────────────────────────────────
WAZUH_VERSION=4.9.2
WAZUH_MANAGER_PORT=1514
WAZUH_API_PORT=55000
WAZUH_INDEXER_PORT=9202
WAZUH_DASHBOARD_PORT=443
WAZUH_INDEXER_HEAP=4g

# CHANGE THESE before production use!
WAZUH_INDEXER_PASSWORD=SecretPassword
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=MyS3cr3tP4ssw0rd

# ── Syslog ────────────────────────────────────────────────────────────────────
SYSLOG_UDP_PORT=514
SYSLOG_TCP_PORT=514

# ── UniFi Poller (Optional) ──────────────────────────────────────────────────
# Remove or leave empty if you don't use UniFi networking equipment.
UNIFI_URL=https://unifi.example.com
UNIFI_USER=unpoller
UNIFI_PASS=changeme
UNIFI_INFLUXDB=unpoller

# ── pfSense Integration ──────────────────────────────────────────────────────
# IP of your pfSense router (for documentation / syslog-ng filter reference)
PFSENSE_HOST=10.0.0.1

# ── Notifications (Optional) ─────────────────────────────────────────────────
# Configure for health check and update notifications.
# Supports Discord webhooks, Matrix, or any HTTP endpoint.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url
# MATRIX_HOMESERVER=https://matrix.example.com
# MATRIX_ROOM_ID=!your-room:matrix.example.com
# MATRIX_ACCESS_TOKEN=your-access-token
